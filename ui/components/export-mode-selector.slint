import { ComboBox, SpinBox } from "std-widgets.slint";

export component ExportModeSelector inherits HorizontalLayout {
    in-out property <int> mode: 1;
    in-out property <int> requested-lap: 1;
    in property <bool> busy: false;

    height: 36px;
    spacing: 12px;

    Text {
        width: 120px;
        text: "Export mode";
        color: #d8e2eb;
        vertical-alignment: center;
    }

    mode-picker := ComboBox {
        width: 260px;
        model: ["All laps in one file", "One file per lap", "A specific lap"];
        current-index: root.mode == 1 ? 0 : root.mode == 0 ? 1 : 2;
        enabled: !root.busy;
        selected(value) => {
            root.mode = self.current-index == 0 ? 1
                : self.current-index == 1 ? 0
                : 2;
        }
    }

    Text {
        text: "Lap number";
        color: root.mode == 2 ? #d8e2eb : #637586;
        vertical-alignment: center;
    }

    SpinBox {
        width: 110px;
        minimum: 1;
        maximum: 9999;
        value <=> root.requested-lap;
        enabled: !root.busy && root.mode == 2;
    }
}

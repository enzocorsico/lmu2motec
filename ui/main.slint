import { TelemetryFile } from "models.slint";
import { AppHeader } from "components/app-header.slint";
import { ConversionStatusBar } from "components/conversion-status-bar.slint";
import { ExportModeSelector } from "components/export-mode-selector.slint";
import { SourceFolderSelector } from "components/source-folder-selector.slint";
import { SetupExportOption } from "components/setup-export-option.slint";
import { TelemetryFileList } from "components/telemetry-file-list.slint";
import { OutputFolderSelector } from "components/output-folder-selector.slint";

export component MainWindow inherits Window {
    title: "LMU to MoTeC";
    preferred-width: 1100px;
    preferred-height: 680px;
    min-width: 720px;
    min-height: 520px;
    background: #111820;

    in-out property <string> source-folder;
    in-out property <string> output-folder;
    in property <[TelemetryFile]> files;
    in property <string> status-text: "Choose a folder containing DuckDB files.";
    in property <bool> busy: false;
    in property <int> selected-count: 0;
    in property <int> progress-value: 0;
    in property <int> progress-max: 0;
    in-out property <int> export-mode: 1;
    in-out property <int> requested-lap: 1;
    in-out property <bool> export-setup: false;

    callback browse-source();
    callback browse-output();
    callback open-output-folder();
    callback save-settings();
    callback refresh-files();
    callback select-all(bool);
    callback toggle-file(int, bool);
    callback convert-selected();
    callback stop-conversion();

    background-focus := FocusScope {
        width: parent.width;
        height: parent.height;
        focus-on-click: true;
    }

    VerticalLayout {
        padding: 24px;
        spacing: 14px;

        AppHeader {}

        SourceFolderSelector {
            folder <=> root.source-folder;
            busy: root.busy;
            browse => { root.browse-source(); }
            refresh => { root.refresh-files(); }
            folder-edited => { root.refresh-files(); }
        }

        TelemetryFileList {
            vertical-stretch: 1;
            files: root.files;
            selected-count: root.selected-count;
            busy: root.busy;
            refresh => { root.refresh-files(); }
            select-all(selected) => { root.select-all(selected); }
            toggle-file(index, selected) => { root.toggle-file(index, selected); }
        }

        OutputFolderSelector {
            folder <=> root.output-folder;
            busy: root.busy;
            browse => { root.browse-output(); }
            open-folder => { root.open-output-folder(); }
            folder-edited => { root.save-settings(); }
        }

        ExportModeSelector {
            mode <=> root.export-mode;
            requested-lap <=> root.requested-lap;
            busy: root.busy;
        }

        SetupExportOption {
            export-setup <=> root.export-setup;
            busy: root.busy;
        }

        ConversionStatusBar {
            status-text: root.status-text;
            busy: root.busy;
            can-convert: root.selected-count > 0 && root.output-folder != "";
            progress-value: root.progress-value;
            progress-max: root.progress-max;
            convert => { root.convert-selected(); }
            stop => { root.stop-conversion(); }
        }
    }
}
